# Public site origin used to build canonical / OG URLs (SEO-03).
NEXT_PUBLIC_SITE_URL=https://finsight.ai

# NestJS internal API base for the materialised-store read path (SEO-04).
API_BASE=http://localhost:3001

# Server-side only secret for internal report reads. NEVER prefix with
# NEXT_PUBLIC_ (would leak to the client bundle — threat T-08-04).
INTERNAL_API_SECRET=

# Optional: public instrument-master base for generateStaticParams + dual-
# listing canonical. Unset until the Phase-2 public endpoint exists; pages
# fall back to on-demand ISR with NSE-symbol canonical (see instrument-master.ts).
PUBLIC_INSTRUMENTS_BASE=
