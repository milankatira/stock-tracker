# Test-mode env defaults. The Zod schema (Plan 02) validates these at boot;
# all *_SECRET values are ≥32 chars so validation passes during tests.
# Vitest setup.ts overrides MONGO_URI at runtime with the in-memory
# replica-set URI.
NODE_ENV=test
PORT=3001
MONGO_URI=mongodb://localhost:27017/finsight-test
REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=test-access-secret-must-be-at-least-32chars
JWT_REFRESH_SECRET=test-refresh-secret-must-be-at-least-32chars
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800
GOOGLE_CLIENT_ID=test.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=test-google-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback
GEMINI_API_KEY=test-gemini-key
WEB_ORIGINS=http://localhost:3000
COOKIE_DOMAIN=localhost
COOKIE_SECRET=test-cookie-secret-must-be-at-least-32chars
CSRF_SECRET=test-csrf-secret-must-be-at-least-32chars
NEXT_PUBLIC_API_URL=http://localhost:3001
