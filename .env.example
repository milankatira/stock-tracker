# FinSight AI — environment variable template
# Copy this file to `.env.local` (per-app) and fill in real values.
# NEVER commit a real `.env` — only `.env.example` is in version control.
#
# Secrets marked with [≥32 chars] are validated by the Plan 02 Zod env schema
# at boot. The API will refuse to start if any of these is missing or short.

# Runtime
NODE_ENV=development
PORT=3001

# MongoDB (local docker-compose: single-node replica set, required for transactions + time-series)
MONGO_URI=mongodb://localhost:27017/finsight?directConnection=true&replicaSet=rs0

# Redis
REDIS_URL=redis://localhost:6379

# JWT secrets [≥32 chars] — rotate per environment
JWT_ACCESS_SECRET=change-me-32-chars-minimum-secret-xx
JWT_REFRESH_SECRET=change-me-32-chars-minimum-secret-yy
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800

# Google OAuth (Cloud Console → OAuth 2.0 Client ID)
GOOGLE_CLIENT_ID=changeme.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=changeme
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

# Gemini (Google AI Studio → API key). Used Phase 4+ but validated at boot now.
GEMINI_API_KEY=changeme

# Cookies / CSRF [COOKIE_SECRET, CSRF_SECRET ≥32 chars]
COOKIE_DOMAIN=localhost
COOKIE_SECRET=change-me-32-chars-minimum-secret-zz
CSRF_SECRET=change-me-32-chars-minimum-secret-cc

# Web → API base URL (exposed to the browser — must NOT be a secret)
NEXT_PUBLIC_API_URL=http://localhost:3001
