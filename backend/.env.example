# Copy to `.env` and fill in real values. `.env` is gitignored.

# MongoDB connection string for watchlist persistence.
# Use a mongodb+srv:// URI from Atlas (the [srv] extra installs dnspython).
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.example.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=tracker
WATCHLIST_COLLECTION=watchlist
# Server selection timeout (ms) — how long a request waits for a reachable cluster.
MONGODB_TIMEOUT_MS=5000

# CORS allow-list (comma-separated); "*" for local dev only.
# CORS_ORIGINS=*
